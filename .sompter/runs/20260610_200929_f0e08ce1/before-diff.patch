+  gap: 6px;
+  padding-top: 4px;
+}
+
+.skeleton-line {
+  height: 10px;
+  background: #3d3d5c;
+  border-radius: 4px;
+  animation: skeleton-pulse 1.5s ease-in-out infinite;
+}
+
+.skeleton-line:nth-child(2) { width: 85%; }
+.skeleton-line:nth-child(3) { width: 55%; }
+
+@keyframes skeleton-pulse {
+  0%, 100% { opacity: 0.3; }
+  50% { opacity: 0.6; }
+}
+
+/* Auto-scroll button */
+#scroll-bottom-btn {
+  display: none;
+  position: sticky;
+  bottom: 0;
+  width: 100%;
+  background: linear-gradient(135deg, #2d2d4a, #3d3d5c);
+  border: 1px solid #4a4a6a;
+  color: #a78bfa;
+  padding: 5px;
+  font-size: 10px;
+  font-weight: 600;
+  text-align: center;
+  cursor: pointer;
+  border-radius: 0 0 8px 8px;
+  transition: all 0.15s;
+  letter-spacing: 0.3px;
+}
+#scroll-bottom-btn:hover {
+  background: linear-gradient(135deg, #3d3d5c, #4a4a6a);
+  color: #c4b5fd;
+}
+#scroll-bottom-btn.visible {
+  display: block;
+}
+
+/* Panel slide-in animation */
+.panel-slide {
+  animation: panelSlideIn 0.2s ease-out;
+}
+
+@keyframes panelSlideIn {
+  from { opacity: 0; transform: translateY(-6px); }
+  to { opacity: 1; transform: translateY(0); }
+}
+
+/* Gradient accent on title */
+#title {
+  background: linear-gradient(135deg, #c4b5fd, #7c3aed);
+  -webkit-background-clip: text;
+  -webkit-text-fill-color: transparent;
+  background-clip: text;
+  font-weight: 800;
+  letter-spacing: 0.5px;
+}
+
+header::after {
+  content: '';
+  display: block;
+  height: 2px;
+  margin-top: 4px;
+  background: linear-gradient(90deg, transparent, #7c3aed, #a78bfa, transparent);
+  border-radius: 1px;
+}
+
+/* Gradient send button */
+#send-btn {
+  background: linear-gradient(135deg, #7c3aed, #9a5cff);
+  border: none;
+  transition: all 0.15s;
+}
+#send-btn:hover {
+  background: linear-gradient(135deg, #6d28d9, #7c3aed);
+  box-shadow: 0 0 12px rgba(124,58,237,0.4);
+}
+
+/* Status bar polish */
+#status-text {
+  font-size: 11px;
+  font-weight: 600;
+  letter-spacing: 0.3px;
+}
+
+/* Footer mode polish */
+.footer-mode {
+  color: #a78bfa;
+  font-weight: 700;
+  font-size: 10px;
+  text-transform: uppercase;
+  letter-spacing: 0.5px;
+}
+
+.footer-provider {
+  color: #7c3aed;
+  font-weight: 600;
+  font-size: 10px;
+}
+
+/* Smart Fix button polish */
+#preset-actions .preset-action-btn:first-child {
+  background: linear-gradient(135deg, #7c3aed, #6d28d9);
+  box-shadow: 0 0 8px rgba(124,58,237,0.3);
+}
+#preset-actions .preset-action-btn:first-child:hover {
+  box-shadow: 0 0 16px rgba(124,58,237,0.5);
+}
